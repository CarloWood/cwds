#pragma once

namespace config {

// NAMESPACE_DEBUG
//
// The name of the namespace that cwds uses to put debug related symbols in.

#cmakedefine NAMESPACE_DEBUG @NAMESPACE_DEBUG@


// HAVE_LIBBOOST
//
// Defined if Boost was found and Boost::boost is publically linked.

#cmakedefine HAVE_LIBBOOST @HAVE_LIBBOOST@

} // namespace config
